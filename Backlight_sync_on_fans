blueprint:
  name: Helper & Backlights Sync to Fan
  description: >
    Sync an input_boolean helper with one or more fans, and optionally keep LED indicator
    switches set to the inverse of the fan state.


    - 💨 If **any** fan is on, the helper turns on and LEDs turn off.

    - 🌑 If **all** fans are off, the helper turns off and LEDs turn on.

    - ⚠️ If fans are unavailable or unknown, the helper and LEDs are left in their current
    state (no change).

    - 🔄 Only fires on meaningful on/off transitions — attribute-only changes (speed,
    percentage, oscillation, preset mode, direction, etc.) are ignored.

  domain: automation
  input:
    main_fans:
      name: Fan(s)
      description: >
        One or more fan entities to read. The helper and LEDs will be synced whenever
        any of these fans turn on or off.
      selector:
        entity:
          domain: fan
          multiple: true
    helper_entity:
      name: Helper
      description: >
        Input boolean to sync with the fan(s). Turns on when any fan is on,
        off when all fans are off.
      selector:
        entity:
          domain: input_boolean
    led_entities:
      name: LED Indicators
      description: >
        Optional — switches to reflect the opposite state of your fan(s).
        Leave empty if not required.
      default: []
      selector:
        entity:
          domain: switch
          multiple: true

# FIX #1: Split into two explicit triggers with from/to constraints so the automation
# only fires on real on<->off transitions. This is especially important for fans, which
# generate significant attribute chatter (speed, percentage, oscillation, preset mode,
# direction) that would otherwise cause spurious helper and LED updates.
trigger:
  - platform: state
    entity_id: !input main_fans
    from: "off"
    to: "on"
    id: 'fan_turned_on'
  - platform: state
    entity_id: !input main_fans
    from: "on"
    to: "off"
    id: 'fan_turned_off'

variables:
  main_fans: !input main_fans
  led_entities: !input led_entities

action:
  # ── SYNC HELPER ────────────────────────────────────────────────────────────
  # Policy: any fan on → helper on; all fans off → helper off.
  # FIX #3: Added default: [] to explicitly handle unavailable/unknown states
  # gracefully — helper is left unchanged rather than being set incorrectly.
  - choose:
      # Any fan is on → helper ON
      - conditions:
          - condition: state
            entity_id: !input main_fans
            match: any
            state: 'on'
        sequence:
          - service: input_boolean.turn_on
            target:
              entity_id: !input helper_entity
      # All fans are off → helper OFF
      - conditions:
          - condition: state
            entity_id: !input main_fans
            match: all
            state: 'off'
        sequence:
          - service: input_boolean.turn_off
            target:
              entity_id: !input helper_entity
    # FIX #3: Fans unavailable/unknown — leave helper as-is.
    default: []

  # ── SYNC LED INDICATORS (inverse of fans) ──────────────────────────────────
  # Policy: any fan on → LEDs OFF; all fans off → LEDs ON.
  # FIX #2: Wrapped in an outer choose that guards against empty led_entities,
  # preventing unnecessary service calls and log warnings.
  # FIX #3: Added default: [] to handle unavailable/unknown states — LEDs left unchanged.
  - choose:
      - conditions:
          - condition: template
            # FIX #2: Only proceed if LED entities have been configured.
            value_template: "{{ led_entities != [] }}"
        sequence:
          - choose:
              # Any fan is on → LEDs OFF (inverse)
              - conditions:
                  - condition: state
                    entity_id: !input main_fans
                    match: any
                    state: 'on'
                sequence:
                  - service: switch.turn_off
                    target:
                      entity_id: !input led_entities
              # All fans are off → LEDs ON (inverse)
              - conditions:
                  - condition: state
                    entity_id: !input main_fans
                    match: all
                    state: 'off'
                sequence:
                  - service: switch.turn_on
                    target:
                      entity_id: !input led_entities
            # FIX #3: Fans unavailable/unknown — leave LEDs as-is.
            default: []

mode: single
